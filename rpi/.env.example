# Smart Stick RPi backend configuration template.
# Copy to `.env` and adjust for the target environment.

# --- Runtime ---
SMART_STICK_ENV=dev
LOG_LEVEL=INFO

# --- Storage paths ---
DATA_DIR=/home/pi/data
DATABASE_PATH=/home/pi/data/smartstick.db
CSV_LOG_PATH=/home/pi/data/electrical_parameters.csv

# --- API ---
API_HOST=0.0.0.0
API_PORT=5000
API_CORS_ORIGINS=*

# --- Detection ---
DETECTION_ENABLED=true
DETECTION_FPS=6
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_IMG_SIZE=640

# --- Camera ---
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# --- GPS (UART) ---
GPS_PORT=/dev/ttyUSB0
GPS_BAUDRATE=9600
GPS_UPDATE_INTERVAL_S=5

# --- LIDAR (I2C) ---
LIDAR_I2C_BUS=1
LIDAR_I2C_ADDRESS=16

# --- Ultrasonic ---
ULTRASONIC_OVERHEAD_TRIG_PIN=23
ULTRASONIC_OVERHEAD_ECHO_PIN=25
ULTRASONIC_DOWN_TRIG_PIN=24
ULTRASONIC_DOWN_ECHO_PIN=22

# --- IMU (I2C) ---
IMU_I2C_BUS=1
IMU_I2C_ADDRESS=104

# --- Battery ---
BATTERY_UPDATE_INTERVAL_S=30
BATTERY_WARN_50=true
BATTERY_WARN_25=true
BATTERY_WARN_10=true

# --- ESP32 (UART) ---
ESP32_PORT=/dev/serial0
ESP32_BAUDRATE=115200

# --- Output ---
HAPTICS_PIN=26
BUZZER_PIN=27

# --- Alerting ---
ALERT_COOLDOWN_S=3.0
ELECTRICAL_LOG_INTERVAL_S=30

# --- TTS ---
TTS_RATE_WPM=150
TTS_VOLUME=1.0
